{
  "name": "sqlite-nas-sync",
  "version": "0.7.0",
  "description": "Sync SQLite databases across multiple clients via NAS with changelog-based conflict resolution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "typedoc",
    "docs:serve": "typedoc && npx serve docs/api -l 3333",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sqlite",
    "nas",
    "sync",
    "database",
    "conflict-resolution",
    "multi-client",
    "changelog"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "better-sqlite3": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "typedoc": "^0.28.16",
    "typescript": "^5.4.5",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=16.0.0"
  }
}
